# Porta da API
API_PORT=3000

# URL da base de dados Postgres (ex: postgresql://usuario:senha@db:5432/nexora)
DATABASE_URL=postgresql://postgres:postgres@db:5432/nexora

# URL do Redis
REDIS_URL=redis://redis:6379

# Segredos para assinar tokens JWT (substitua por valores fortes em produção)
JWT_SECRET=acesso_super_secreto
JWT_REFRESH_SECRET=refresh_super_secreto

# Tempo de expiração dos tokens em segundos
JWT_EXPIRES_IN=900         # 15 minutos
JWT_REFRESH_EXPIRES_IN=604800  # 7 dias

# Origem permitida para CORS (ex.: http://localhost:3001)
CORS_ORIGIN=http://localhost:3001

# Lista de e‑mails permitidos para se registrar como administrador (se vazio, qualquer)
ALLOWED_EMAILS=

# URL pública da API utilizada pelo frontend
NEXT_PUBLIC_API_URL=http://localhost:3000